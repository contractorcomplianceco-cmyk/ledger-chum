# LedgerOS frontend — production API wiring.
# Leave defaults for the Design Lab (mock adapter). Populate the URL and set
# mode=production when the Express backend is ready to serve requests.

VITE_LEDGEROS_API_BASE_URL=
VITE_LEDGEROS_API_MODE=mock
VITE_LEDGEROS_USE_CREDENTIALS=true

# ---------------------------------------------------------------------------
# App data mode. "demo" (default) runs fully simulated with no network/secrets
# and simulates email/payments. "production" wires real server functions, the
# live payment gateway, and real email connections from stored config.
# ---------------------------------------------------------------------------
VITE_APP_MODE=demo
# Server-side mirror of the mode (read by server fns / route handlers).
APP_MODE=demo

# --- Phase B: AI invoice styling ---------------------------------------------
# The style engine is provider-agnostic. Leaving these unset uses the built-in
# deterministic local heuristic (fully functional, no model required).
#
# To route prompts through a real model instead:
#   1. Set the CLIENT flag to any non-"local" label so the UI uses LLMStyleProvider:
VITE_INVOICE_AI_PROVIDER=local
#   2. Set the SERVER-ONLY values below (never prefixed VITE_, so they stay off the
#      client bundle). When present the server calls the model and validates/clamps
#      its output; if anything fails it falls back to the local heuristic.
# INVOICE_AI_PROVIDER=openai
# INVOICE_AI_API_KEY=
# INVOICE_AI_BASE_URL=https://api.openai.com/v1
# INVOICE_AI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Email integration — SERVER-ONLY. These are NEVER prefixed VITE_ and must not
# be exposed to the client bundle. They are optional fallback defaults; per-org
# config stored in the `email_settings` table (set via Settings → Email)
# overrides any value set here. Only used when VITE_APP_MODE=production.
#
# Provider-agnostic: works with Zoho, Gmail/Workspace, or any custom SMTP host.
#
# Outbound (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false            # true for implicit TLS (port 465), false for STARTTLS (587)
SMTP_USERNAME=
SMTP_PASSWORD=               # use an app-specific password when 2FA is enabled
SMTP_FROM_NAME=
SMTP_FROM_ADDRESS=
#
# Inbound (IMAP or POP3)
INBOUND_PROTOCOL=imap        # imap | pop3
INBOUND_HOST=
INBOUND_PORT=993             # 993 IMAPS, 995 POP3S
INBOUND_SECURE=true
INBOUND_USERNAME=
INBOUND_PASSWORD=

# ---------------------------------------------------------------------------
# Payments — processor-agnostic (Phase C). Pick the live provider (defaults
# follow APP_MODE: demo -> DemoPaymentProvider, production -> Authorize.net when
# configured). Override explicitly with: demo | authorize_net
# ---------------------------------------------------------------------------
PAYMENT_PROVIDER=

# Authorize.net (SERVER-ONLY secrets — never expose to the client).
# Card + eCheck/ACH via Accept.js / Accept Hosted tokenized flow.
AUTHORIZENET_ENV=sandbox              # sandbox | production
AUTHORIZENET_API_LOGIN_ID=           # public API login id (also used by tokenizer)
AUTHORIZENET_TRANSACTION_KEY=        # SECRET — server-side charges/refunds
AUTHORIZENET_CLIENT_KEY=             # public client key for Accept.js tokenizer
AUTHORIZENET_SIGNATURE_KEY=          # SECRET — HMAC-SHA512 webhook verification
