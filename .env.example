# LedgerOS frontend — production API wiring.
# Leave defaults for the Design Lab (mock adapter). Populate the URL and set
# mode=production when the Express backend is ready to serve requests.

VITE_LEDGEROS_API_BASE_URL=
VITE_LEDGEROS_API_MODE=mock
VITE_LEDGEROS_USE_CREDENTIALS=true

# ---------------------------------------------------------------------------
# App data mode. "demo" (default) runs fully simulated with no network/secrets;
# "production" wires real server functions and the live payment gateway.
# ---------------------------------------------------------------------------
VITE_APP_MODE=demo
# Server-side mirror of the mode (read by server fns / route handlers).
APP_MODE=demo

# ---------------------------------------------------------------------------
# Payments — processor-agnostic. Pick the live provider (defaults follow
# APP_MODE: demo -> DemoPaymentProvider, production -> Authorize.net when
# configured). Override explicitly with: demo | authorize_net
# ---------------------------------------------------------------------------
PAYMENT_PROVIDER=

# Authorize.net (SERVER-ONLY secrets — never expose to the client).
# Card + eCheck/ACH via Accept.js / Accept Hosted tokenized flow.
AUTHORIZENET_ENV=sandbox              # sandbox | production
AUTHORIZENET_API_LOGIN_ID=           # public API login id (also used by tokenizer)
AUTHORIZENET_TRANSACTION_KEY=        # SECRET — server-side charges/refunds
AUTHORIZENET_CLIENT_KEY=             # public client key for Accept.js tokenizer
AUTHORIZENET_SIGNATURE_KEY=          # SECRET — HMAC-SHA512 webhook verification
