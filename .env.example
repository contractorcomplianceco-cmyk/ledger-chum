# LedgerOS frontend — production API wiring.
# Leave defaults for the Design Lab (mock adapter). Populate the URL and set
# mode=production when the Express backend is ready to serve requests.

VITE_LEDGEROS_API_BASE_URL=
VITE_LEDGEROS_API_MODE=mock
VITE_LEDGEROS_USE_CREDENTIALS=true

# ---------------------------------------------------------------------------
# Data mode. `demo` (default) uses in-memory fixtures and simulates email with
# no real network. `production` uses real connections from stored config.
VITE_APP_MODE=demo

# ---------------------------------------------------------------------------
# Email integration — SERVER-ONLY. These are NEVER prefixed VITE_ and must not
# be exposed to the client bundle. They are optional fallback defaults; per-org
# config stored in the `email_settings` table (set via Settings → Email)
# overrides any value set here. Only used when VITE_APP_MODE=production.
#
# Provider-agnostic: works with Zoho, Gmail/Workspace, or any custom SMTP host.
#
# Outbound (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false            # true for implicit TLS (port 465), false for STARTTLS (587)
SMTP_USERNAME=
SMTP_PASSWORD=               # use an app-specific password when 2FA is enabled
SMTP_FROM_NAME=
SMTP_FROM_ADDRESS=
#
# Inbound (IMAP or POP3)
INBOUND_PROTOCOL=imap        # imap | pop3
INBOUND_HOST=
INBOUND_PORT=993             # 993 IMAPS, 995 POP3S
INBOUND_SECURE=true
INBOUND_USERNAME=
INBOUND_PASSWORD=
