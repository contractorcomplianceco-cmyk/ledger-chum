# LedgerOS frontend — production API wiring.
# Leave defaults for the Design Lab (mock adapter). Populate the URL and set
# mode=production when the Express backend is ready to serve requests.

VITE_LEDGEROS_API_BASE_URL=
VITE_LEDGEROS_API_MODE=mock
VITE_LEDGEROS_USE_CREDENTIALS=true

# ---------------------------------------------------------------------------
# External CCA integrations (server-only; NEVER expose these as VITE_* vars).
# Leave BASE_URL blank to keep an integration stubbed/disabled. See
# docs/integrations/README.md for the contracts and live-vs-stub status.
# ---------------------------------------------------------------------------

# AuditEngine (Audit-Risk-Model) — governed source of truth; read-only.
AUDITENGINE_BASE_URL=
AUDITENGINE_API_KEY=

# SalesCoreOS (CCA-SalesIntelligenceOS) — sales-enablement + CRM reads.
SALESCORE_BASE_URL=
SALESCORE_API_KEY=

# DocumentCollectionOS (Document-Collection) — docs-collect export feed.
DOCUMENTCOLLECTION_BASE_URL=
DOCUMENTCOLLECTION_EXPORT_TOKEN=

# ComplianceConnectOS (Client-Portal) — approved compliance scores + monitoring.
COMPLIANCECONNECT_BASE_URL=
COMPLIANCECONNECT_API_KEY=
